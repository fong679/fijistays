// ─────────────────────────────────────────────────────
//  FijiStays — Prisma Schema
//  PostgreSQL 16 | UUID primary keys | Audit fields
// ─────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum UserRole {
  TOURIST
  HOST
  ADMIN
}

enum ExperienceType {
  HOMESTAY
  KAVA_CEREMONY
  GUIDED_HIKE
  REEF_FISHING
  COOKING_CLASS
  CULTURAL_TOUR
  MULTI_DAY_PACKAGE
  ECO_TOUR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  MPAISA
  PAYPAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum IslandGroup {
  VITI_LEVU
  VANUA_LEVU
  YASAWA
  MAMANUCA
  KADAVU
  LAU
  ROTUMA
  LOMAIVITI
  OTHER
}

// ─── Users ────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  role           UserRole  @default(TOURIST)
  firstName      String
  lastName       String
  phone          String?
  avatarUrl      String?
  isVerified     Boolean   @default(false)
  verifiedAt     DateTime?
  isActive       Boolean   @default(true)
  refreshToken   String?   // hashed
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  villages       Village[]
  bookings       Booking[]
  reviews        Review[]
  auditLogs      AuditLog[]

  @@map("users")
}

// ─── Villages ─────────────────────────────────────────

model Village {
  id             String      @id @default(uuid())
  hostId         String
  name           String
  description    String
  islandGroup    IslandGroup
  island         String      // specific island name
  province       String?
  latitude       Float
  longitude      Float
  tltbPermitUrl  String?     // iTaukei Land Trust Board permit
  isVerified     Boolean     @default(false)
  verifiedAt     DateTime?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  host           User          @relation(fields: [hostId], references: [id])
  experiences    Experience[]
  protocols      VillageProtocol[]
  images         VillageImage[]

  @@map("villages")
}

model VillageImage {
  id         String   @id @default(uuid())
  villageId  String
  url        String
  altText    String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  village    Village  @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@map("village_images")
}

// ─── Cultural Protocols ───────────────────────────────

model CulturalProtocol {
  id               String    @id @default(uuid())
  name             String
  descriptionEn    String
  descriptionFj    String?   // Fijian language
  isMandatory      Boolean   @default(false)
  touristMustAck   Boolean   @default(true)
  createdAt        DateTime  @default(now())

  villageProtocols VillageProtocol[]
  bookingAcks      BookingProtocolAck[]

  @@map("cultural_protocols")
}

model VillageProtocol {
  villageId   String
  protocolId  String

  village     Village          @relation(fields: [villageId], references: [id], onDelete: Cascade)
  protocol    CulturalProtocol @relation(fields: [protocolId], references: [id])

  @@id([villageId, protocolId])
  @@map("village_protocols")
}

// ─── Experiences ──────────────────────────────────────

model Experience {
  id             String         @id @default(uuid())
  villageId      String
  title          String
  description    String
  type           ExperienceType
  pricePerPerson Float          // FJD
  maxGuests      Int
  durationHours  Float
  includesFood   Boolean        @default(false)
  includesTransfer Boolean      @default(false)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  village        Village          @relation(fields: [villageId], references: [id])
  bookings       Booking[]
  availability   Availability[]
  images         ExperienceImage[]

  @@map("experiences")
}

model ExperienceImage {
  id           String     @id @default(uuid())
  experienceId String
  url          String
  isPrimary    Boolean    @default(false)
  createdAt    DateTime   @default(now())

  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@map("experience_images")
}

// ─── Availability (with optimistic locking) ───────────

model Availability {
  id           String     @id @default(uuid())
  experienceId String
  date         DateTime   @db.Date
  spotsTotal   Int
  spotsBooked  Int        @default(0)
  version      Int        @default(0) // optimistic lock
  isClosed     Boolean    @default(false) // host can close specific dates

  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([experienceId, date])
  @@map("availability")
}

// ─── Bookings ─────────────────────────────────────────

model Booking {
  id               String        @id @default(uuid())
  userId           String
  experienceId     String
  bookingDate      DateTime      @db.Date
  guestCount       Int
  totalFjd         Float
  platformFeeFjd   Float
  villagePayout    Float
  status           BookingStatus @default(PENDING)
  specialRequests  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  user             User                 @relation(fields: [userId], references: [id])
  experience       Experience           @relation(fields: [experienceId], references: [id])
  payment          Payment?
  review           Review?
  protocolAcks     BookingProtocolAck[]

  @@map("bookings")
}

model BookingProtocolAck {
  bookingId   String
  protocolId  String
  ackedAt     DateTime @default(now())

  booking     Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  protocol    CulturalProtocol @relation(fields: [protocolId], references: [id])

  @@id([bookingId, protocolId])
  @@map("booking_protocol_acks")
}

// ─── Payments ─────────────────────────────────────────

model Payment {
  id              String          @id @default(uuid())
  bookingId       String          @unique
  provider        PaymentProvider
  providerRef     String?         // Stripe payment intent ID etc.
  amountFjd       Float
  status          PaymentStatus   @default(PENDING)
  paidAt          DateTime?
  refundedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  booking         Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

// ─── Reviews ──────────────────────────────────────────

model Review {
  id          String   @id @default(uuid())
  userId      String
  bookingId   String   @unique
  rating      Int      // 1–5
  title       String?
  body        String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  booking     Booking  @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}

// ─── Audit Log (immutable) ────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   // e.g. "booking.created", "payment.processed"
  entityType String   // "booking", "payment", "user"
  entityId   String
  metadata   Json?    // before/after state
  ipAddress  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
